generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
  schemas   = ["fitconnect"]
}

model User {
  id                     String           @id @default(cuid())
  clerkId                String           @unique
  name                   String
  email                  String           @unique
  stripeCustomerId       String?          @unique
  subscriptionId         String?
  status                 String           @default("inactive")
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  role                   String           @default("user")
  goal                   String?
  targetDistance         String?
  activeProgramId        String?
  runningProgramId       String?
  fitCoins               Int              @default(0)
  isDeloadActive         Boolean          @default(false)
  lastWorkoutDate        DateTime?
  streak                 Int              @default(0)
  isGuest                Boolean          @default(false)
  whatsapp               String?
  current_training_month Int              @default(1)
  exerciseLoads          ExerciseLoad[]
  oneOffPurchases        OneOffPurchase[]
  subscriptions          Subscription[]
  activeProgram          TrainingProgram? @relation("ActiveProgram", fields: [activeProgramId], references: [id])
  runningProgram         TrainingProgram? @relation("RunningProgram", fields: [runningProgramId], references: [id])
  rewards                UserReward[]
  workoutLogs            WorkoutLog[]

  @@schema("fitconnect")
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  whatsapp    String
  token       String   @unique
  isConfirmed Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@schema("fitconnect")
}

model WorkoutLog {
  id          String   @id @default(cuid())
  userId      String
  workoutId   String
  duration    Int
  effortScale Int
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@schema("fitconnect")
}

model Reward {
  id          String       @id @default(cuid())
  title       String
  description String?
  cost        Int
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  imageUrl    String?
  userRewards UserReward[]

  @@schema("fitconnect")
}

model UserReward {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  claimedAt DateTime @default(now())
  status    String   @default("pending")
  reward    Reward   @relation(fields: [rewardId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@schema("fitconnect")
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  description   String?
  price         Float
  interval      String
  stripePriceId String         @unique
  active        Boolean        @default(true)
  subscriptions Subscription[]

  @@schema("fitconnect")
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  planId               String
  status               String
  stripeSubscriptionId String   @unique
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  plan                 Plan     @relation(fields: [planId], references: [id])
  user                 User     @relation(fields: [userId], references: [id])

  @@schema("fitconnect")
}

model Workout {
  id              String           @id @default(cuid())
  title           String
  description     String?
  category        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  exercises       Exercise[]
  programWorkouts ProgramWorkout[]

  @@schema("fitconnect")
}

model Exercise {
  id            String         @id @default(cuid())
  workoutId     String
  name          String
  description   String?
  youtubeId     String
  sets          String?
  order         Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  videoProvider String         @default("youtube")
  reps          String?
  rest          String?
  isGironda     Boolean        @default(false)
  workout       Workout        @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseLoads ExerciseLoad[]

  @@schema("fitconnect")
}

model OneOffPurchase {
  id        String   @id @default(cuid())
  userId    String
  workoutId String?
  status    String   @default("completed")
  amount    Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@schema("fitconnect")
}

model Tip {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  category  String   @default("musculacao")

  @@schema("fitconnect")
}

model Nutrition {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  category  String   @default("horarios")

  @@schema("fitconnect")
}

model Recipe {
  id           String   @id @default(cuid())
  title        String
  ingredients  String
  instructions String
  calories     Int?
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  category     String   @default("pre-treino")

  @@schema("fitconnect")
}

model TrainingProgram {
  id                 String           @id @default(cuid())
  title              String
  description        String?
  durationDays       Int              @default(30)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  goal               String?
  category           String           @default("GYM")
  companionProgramId String?
  level              String?
  subcategory        String?
  month              Int?
  workouts           ProgramWorkout[]
  users              User[]           @relation("ActiveProgram")
  runningUsers       User[]           @relation("RunningProgram")

  @@schema("fitconnect")
}

model ProgramWorkout {
  id        String          @id @default(cuid())
  programId String
  workoutId String
  label     String
  order     Int
  program   TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  workout   Workout         @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@schema("fitconnect")
}

model HomeWorkout {
  id         String   @id @default(cuid())
  title      String
  instructor String
  level      String
  calories   String
  youtubeId  String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@schema("fitconnect")
}

model ExerciseLoad {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  weight     Float
  unit       String   @default("kg")
  createdAt  DateTime @default(now())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, exerciseId])
  @@schema("fitconnect")
}
